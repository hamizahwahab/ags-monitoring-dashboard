{
  "info": {
    "name": "ASG Crisis API",
    "description": "Postman collection for testing the Crisis API endpoints in ASG Monitoring Dashboard.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://192.168.68.82:8001"
    },
    {
      "key": "apiKey",
      "value": "YOUR-API-KEY-HERE"
    }
  ],
  "item": [
    {
      "name": "Push Crisis",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/crises",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-API-Key",
            "value": "{{apiKey}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"title\":\"Database outage\",\"description\":\"Primary database cluster is unavailable\",\"severity\":\"high\"}"
        }
      }
    },
    {
      "name": "Get Active Crises",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/crises"
      }
    },
    {
      "name": "Resolve Crisis",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/api/crises/1",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{apiKey}}"
          }
        ],
        "description": "Change '1' to the crisis ID you want to resolve"
      }
    }
  ]
}